# Database (Neon)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth (REQUIRED)
NEXTAUTH_URL="https://newsroom.yourdomain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Email (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Google Drive (optional - for image uploads)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# AI Features (optional)
ANTHROPIC_API_KEY=

# Story Intelligence
STORY_INTELLIGENCE_API_KEY=  # API key for batch processor and feedback endpoints
TRENDING_API_KEY=            # API key for ingest and cron endpoints
X_MONITOR_ACCOUNTS=          # Comma-separated X handles to monitor (optional, has defaults)
UMAMI_URL=
UMAMI_USERNAME=
UMAMI_PASSWORD=

# Internal API auth (for media analysis fire-and-forget calls)
INTERNAL_API_SECRET=  # generate with: openssl rand -base64 32

# Scheduled Publishing (optional)
CRON_SECRET=

# Social Publishing (optional)
TOKEN_ENCRYPTION_KEY=  # generate with: openssl rand -hex 32
X_CLIENT_ID=           # Default X app (fallback)
X_CLIENT_SECRET=
X_JOETALKSHOW_CLIENT_ID=    # Per-app X credentials
X_JOETALKSHOW_CLIENT_SECRET=
X_LIZPEEK_CLIENT_ID=
X_LIZPEEK_CLIENT_SECRET=
UMAMI_AMERICAISGOODUS_WEBSITE_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Getty Images (optional - for auto image selection)
GETTY_EMAIL=
GETTY_PASSWORD=
GETTY_CUSTOMER_ID=9871544
GETTY_WORKER_URL=http://localhost:3001
GETTY_WORKER_API_KEY=newsroom-getty-2026
