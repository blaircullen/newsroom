generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         Role      @default(WRITER)
  avatarUrl    String?   @map("avatar_url")
  bio          String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")
  articles       Article[]           @relation("AuthoredArticles")
  comments       Comment[]
  reviews        Review[]
  submittedExemplars ArticleExemplar[] @relation("SubmittedExemplars")
  scanDecisions  ScanPick[]          @relation("ScanPickDecisions")
  cutPulls       CutPull[]

  @@index([role, isActive])
  @@map("users")
}

model Article {
  id                  String           @id @default(cuid())
  headline            String
  subHeadline         String?          @map("sub_headline")
  body                String
  bodyHtml            String?          @map("body_html")
  slug                String?          @unique
  featuredImage       String?          @map("featured_image")
  featuredImageId     String?          @map("featured_image_id")
  imageCredit         String?          @map("image_credit")
  featuredMediaId     String?          @map("featured_media_id")
  featuredMedia       Media?           @relation("FeaturedMedia", fields: [featuredMediaId], references: [id])
  status              ArticleStatus    @default(DRAFT)
  authorId            String           @map("author_id")
  publishedUrl        String?          @map("published_url")
  publishedSite       String?          @map("published_site")
  publishedAt         DateTime?        @map("published_at")
  scheduledPublishAt        DateTime?  @map("scheduled_publish_at")
  scheduledPublishTargetId String?    @map("scheduled_publish_target_id")
  totalPageviews      Int              @default(0) @map("total_pageviews")
  totalUniqueVisitors Int              @default(0) @map("total_unique_visitors")
  analyticsUpdatedAt  DateTime?        @map("analytics_updated_at")
  submittedAt         DateTime?        @map("submitted_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  aiReviewFindings    Json?            @map("ai_review_findings")
  aiReviewStatus      String?          @map("ai_review_status")
  aiReviewedAt        DateTime?        @map("ai_reviewed_at")
  tags                ArticleTag[]
  versions            ArticleVersion[]
  author              User              @relation("AuthoredArticles", fields: [authorId], references: [id])
  comments            Comment[]
  reviews             Review[]

  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@index([status, publishedUrl])
  @@index([updatedAt])
  @@index([status, publishedAt])
  @@index([authorId, status])
  @@index([publishedAt])
  @@index([status, scheduledPublishAt])
  @@index([featuredMediaId])
  @@map("articles")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now()) @map("created_at")
  articles  ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String  @map("article_id")
  tagId     String  @map("tag_id")
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
  @@map("article_tags")
}

model Review {
  id         String   @id @default(cuid())
  articleId  String   @map("article_id")
  reviewerId String   @map("reviewer_id")
  notes      String?
  decision   String
  createdAt  DateTime @default(now()) @map("created_at")
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  reviewer   User     @relation(fields: [reviewerId], references: [id])

  @@index([articleId])
  @@index([reviewerId])
  @@map("reviews")
}

model Comment {
  id        String   @id @default(cuid())
  articleId String   @map("article_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([articleId])
  @@index([userId])
  @@map("comments")
}

model ArticleVersion {
  id          String   @id @default(cuid())
  articleId   String   @map("article_id")
  version     Int
  headline    String
  subHeadline String?  @map("sub_headline")
  body        String
  bodyHtml    String?  @map("body_html")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  changeNote  String?  @map("change_note")
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([createdAt])
  @@map("article_versions")
}

model PublishTarget {
  id              String   @id @default(cuid())
  name            String   @unique
  type            String
  url             String
  apiKey          String?  @map("api_key")
  username        String?
  password        String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  clientId        String?  @map("client_id")
  clientSecret    String?  @map("client_secret")
  myshopifyDomain String?  @map("myshopify_domain")
  blogId          String?  @map("blog_id")
  avatarUrl       String?  @map("avatar_url")
  faviconColor    String?  @map("favicon_color")

  @@map("publish_targets")
}

enum Role {
  WRITER
  EDITOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
  PUBLISHED
  REJECTED
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model CompetitorAccount {
  id              String         @id @default(cuid())
  platform        SocialPlatform
  handle          String
  name            String?
  isActive        Boolean        @default(true) @map("is_active")
  postingPattern  Json?          @map("posting_pattern")
  avgEngagement   Json?          @map("avg_engagement")
  lastScrapedAt   DateTime?      @map("last_scraped_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@unique([platform, handle])
  @@map("competitor_accounts")
}

enum SocialPlatform {
  X
  FACEBOOK
  TRUTHSOCIAL
  INSTAGRAM
}

model SystemAlert {
  id         String    @id @default(cuid())
  type       String    @unique
  message    String
  severity   String    @default("error")
  isActive   Boolean   @default(true) @map("is_active")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("system_alerts")
}

model DailyRecap {
  id        String   @id @default(cuid())
  type      String
  date      DateTime @db.Date
  recap     String   @db.Text
  stats     Json
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([type, date])
  @@index([createdAt])
  @@map("daily_recaps")
}

model ImageCredit {
  id          String   @id @default(cuid())
  driveFileId String   @unique @map("drive_file_id")
  credit      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("image_credits")
}

model Media {
  id            String    @id @default(cuid())
  filename      String
  originalName  String    @map("original_name")
  mimeType      String    @map("mime_type")
  format        String
  fileSize      Int       @map("file_size")
  width         Int?
  height        Int?
  credit        String?
  photographer  String?
  source        String?
  licenseType   String?   @map("license_type")
  altText       String?   @map("alt_text")
  description   String?
  tags          String[]  @default([])
  usageCount    Int       @default(0) @map("usage_count")
  uploadedById  String?   @map("uploaded_by_id")
  driveFileId   String?   @unique @map("drive_file_id")
  aiStatus      String?   @default("pending") @map("ai_status")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  articles      Article[] @relation("FeaturedMedia")

  @@index([createdAt])
  @@index([tags], type: Gin)
  @@map("media")
}

enum ExemplarStatus {
  PENDING
  PREVIEW_READY
  ANALYZED
  FAILED
}

model ArticleExemplar {
  id              String          @id @default(cuid())
  url             String          @unique
  title           String?
  source          String?
  category        String?
  status          ExemplarStatus  @default(PENDING)
  quickSummary    String?         @map("quick_summary")
  detectedTopics  String[]        @map("detected_topics")
  fingerprint     Json?
  rawContent      String?         @map("raw_content")
  wordCount       Int?            @map("word_count")
  submittedById   String          @map("submitted_by_id")
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  analyzedAt      DateTime?       @map("analyzed_at")

  submittedBy     User            @relation("SubmittedExemplars", fields: [submittedById], references: [id])

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("article_exemplars")
}

model ScanRun {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now()) @map("created_at")
  status      String     @default("PROCESSING")
  rawCount    Int?       @map("raw_count")
  pickedCount Int?       @map("picked_count")
  completedAt DateTime?  @map("completed_at")
  picks       ScanPick[]

  @@index([createdAt])
  @@map("scan_runs")
}

model ScanPick {
  id            String    @id @default(cuid())
  scanRunId     String    @map("scan_run_id")
  scanRun       ScanRun   @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  rank          Int
  title         String
  summary       String    @db.Text
  url           String
  source        String
  category      String
  priority      String
  status        String    @default("PENDING")
  skipReason    String?   @map("skip_reason")
  feedbackNotes String?   @db.Text @map("feedback_notes")
  processedAt   DateTime? @map("processed_at")
  processedById String?   @map("processed_by_id")
  processedBy   User?     @relation("ScanPickDecisions", fields: [processedById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  articleId     String?   @map("article_id")
  telegramMsgId Int?      @map("telegram_msg_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([scanRunId])
  @@index([status])
  @@index([createdAt])
  @@map("scan_picks")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  userId       String?  @map("user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// "Broadcast Cuts" -- Grabien NewsBase clip pulls. See
// docs/grabien-clipper-feature-design.md §5/§6. One row per clip render
// request submitted to the grabien-api wrapper service; `stage` mirrors the
// wrapper's ClipJob.stage vocabulary exactly (QUEUED/SUBMITTING/RENDERING/
// DOWNLOADING/RAW_READY/FAILED) so no translation layer is needed between
// the two sides.
model CutPull {
  id               String   @id @default(cuid())
  wrapperJobId     String?  @map("wrapper_job_id")
  stage            String   @default("QUEUED") // QUEUED | SUBMITTING | RENDERING | DOWNLOADING | RAW_READY | FAILED
  candidateJson    Json     @map("candidate_json") // CutCandidate snapshot (station/show/airDate/headline/summary/thumb)
  intendedStartMs  Int      @map("intended_start_ms")
  intendedEndMs    Int      @map("intended_end_ms")
  rawDurationS     Int?     @map("raw_duration_s")
  mp4Path          String?  @map("mp4_path")
  metadataPath     String?  @map("metadata_path")
  errorStage       String?  @map("error_stage")
  errorMessage     String?  @db.Text @map("error_message") // verbatim backend cause -- never collapsed to a generic
  trimIntentJson   Json?    @map("trim_intent_json") // v1 stub: recorded "sent to trim" + intended bounds (§6 item 8)
  createdById      String   @map("created_by_id")
  createdBy        User     @relation(fields: [createdById], references: [id])
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([stage])
  @@index([createdAt])
  @@map("cut_pulls")
}
